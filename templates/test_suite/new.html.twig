{% extends 'base.html.twig' %}

{% block title %}New Test Suite for {{ project.name }}{% endblock %}

{% block body %}
    <h1>Create Test Suite in {{ project.name }}</h1>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label for="name" class="form-label">Test Suite Name</label>
                    <input type="text" id="name" name="name" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea id="description" name="description" class="form-control" rows="3"></textarea>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_project_show', {'id': project.id}) }}" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Test Suite</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
