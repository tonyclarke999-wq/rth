{% extends 'base.html.twig' %}

{% block title %}Bug #{{ bug.id }}: {{ bug.summary }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Bug Details</h1>
        <div>
            <a href="{{ path('app_project_show', {'id': bug.project.id}) }}" class="btn btn-outline-secondary">Back to Project</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4 border-danger">
                <div class="card-body">
                    <h5 class="card-title text-danger">#{{ bug.id }} - {{ bug.summary }}</h5>
                    <hr>
                    <div class="bug-description p-3 bg-light rounded border mb-4">
                        <h6>Description</h6>
                        {{ bug.description|default('No description provided.')|nl2br }}
                    </div>

                    {% if bug.attachments|length > 0 %}
                        <h6>Attachments</h6>
                        <div class="list-group">
                            {% for attachment in bug.attachments %}
                                <a href="{{ asset('uploads/attachments/' ~ attachment.filename) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" target="_blank">
                                    <div>
                                        <i class="bi bi-file-earmark"></i>
                                        {{ attachment.originalFilename }}
                                    </div>
                                    <span class="badge bg-secondary rounded-pill">{{ (attachment.fileSize / 1024)|round(2) }} KB</span>
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    Metadata
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><strong>Project:</strong> {{ bug.project.name }}</li>
                        <li class="mb-2">
                            <strong>Status:</strong> 
                            <span class="badge bg-info text-dark">{{ bug.status }}</span>
                        </li>
                        <li class="mb-2">
                            <strong>Severity:</strong> 
                            <span class="badge {{ bug.severity == 'Critical' or bug.severity == 'Blocker' ? 'bg-danger' : 'bg-warning text-dark' }}">
                                {{ bug.severity }}
                            </span>
                        </li>
                        <li class="mb-2"><strong>Priority:</strong> {{ bug.priority }}</li>
                        {% if bug.requirement %}
                            <li class="mb-2"><strong>Requirement:</strong> <a href="{{ path('app_requirement_show', {'id': bug.requirement.id}) }}">{{ bug.requirement.name }}</a></li>
                        {% endif %}
                        {% if bug.testCase %}
                            <li class="mb-2"><strong>Test Case:</strong> {{ bug.testCase.name }}</li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
