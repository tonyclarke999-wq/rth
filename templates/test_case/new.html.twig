{% extends 'base.html.twig' %}

{% block title %}New Test Case for {{ project.name }}{% endblock %}

{% block body %}
    <h1>Create Test Case in {{ project.name }}</h1>

    <div class="card shadow-sm mt-4">
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label for="name" class="form-label">Test Case Name</label>
                    <input type="text" id="name" name="name" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea id="description" name="description" class="form-control" rows="5"></textarea>
                </div>
                <div class="mb-3">
                    <label for="testSuite" class="form-label">Test Suite (Optional)</label>
                    <select id="testSuite" name="testSuite" class="form-select">
                        <option value="">-- None --</option>
                        {% for suite in test_suites %}
                            <option value="{{ suite.id }}">{{ suite.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="mb-3">
                    <label for="status" class="form-label">Status</label>
                    <select id="status" name="status" class="form-select">
                        <option value="New">New</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Passed">Passed</option>
                        <option value="Failed">Failed</option>
                    </select>
                </div>
                <div class="d-flex justify-content-between">
                    <a href="{{ path('app_project_show', {'id': project.id}) }}" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">Save Test Case</button>
                </div>
            </form>
        </div>
    </div>
{% endblock %}
