{% extends 'base.html.twig' %}

{% block title %}Requirement: {{ requirement.name }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Requirement Details</h1>
        <div>
            <a href="{{ path('app_project_show', {'id': requirement.project.id}) }}" class="btn btn-outline-secondary">Back to Project</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title text-primary">{{ requirement.name }}</h5>
                    <hr>
                    <div class="requirement-content p-3 bg-light rounded border">
                        {{ requirement.content|default('No content provided.')|nl2br }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    Metadata
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2"><strong>ID:</strong> {{ requirement.id }}</li>
                        <li class="mb-2"><strong>Project:</strong> {{ requirement.project.name }}</li>
                        <li class="mb-2">
                            <strong>Status:</strong> 
                            <span class="badge {{ requirement.status == 'Approved' ? 'bg-success' : 'bg-warning' }}">
                                {{ requirement.status }}
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
